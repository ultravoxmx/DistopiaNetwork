{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ServerSettings": {
    "ServerId": "server-a",
    "Port": 5000,
    "CacheDirectory": "./mp3cache",
    "PeerServers": [
      "http://localhost:5001"
    ],
    "SyncIntervalSeconds": 60,
    "CacheCleanupIntervalSeconds": 3600
  }
}
